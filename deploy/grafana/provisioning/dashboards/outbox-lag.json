{
  "title": "Outbox Lag",
  "uid": "outbox-lag",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["chassis", "outbox"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Outbox Lag (p50 / p95) by Module",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 120 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, module) (rate(chassis_outbox_lag_seconds_bucket[5m])))",
          "legendFormat": "p50 - {{module}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, module) (rate(chassis_outbox_lag_seconds_bucket[5m])))",
          "legendFormat": "p95 - {{module}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Max Outbox Lag (last 5m)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 120 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["max"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(chassis_outbox_lag_seconds_bucket[5m])))",
          "legendFormat": "p99 lag",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Outbox Depth (undelivered messages)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum by (module) (chassis_outbox_depth)",
          "legendFormat": "{{module}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox Depth Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "chassis_outbox_depth",
          "legendFormat": "{{module}}",
          "refId": "A"
        }
      ]
    }
  ]
}
