<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId>SaasBuilder.Modules.FeatureFlags.Contracts</PackageId>
    <Description>Public contracts (evaluation context, flag values) for the FeatureFlags module.</Description>
    <Title>SaasBuilder FeatureFlags Contracts</Title>
    <Authors>SaasBuilder</Authors>
    <Company>SaasBuilder</Company>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/saasbuilder/modular-sdk-dotnet</RepositoryUrl>
    <PackageTags>saasbuilder;featureflags;openfeature;contracts</PackageTags>
  </PropertyGroup>

  <ItemGroup Label="Versioning">
    <PackageReference Include="MinVer" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="Analyzers — build-time only">
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="StyleCop configuration">
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)..\..\..\..\stylecop.json" />
  </ItemGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);SA1101;SA1309;SA0001;SA1600;SA1200;SA1206</NoWarn>
  </PropertyGroup>

</Project>
