<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId>SaasBuilder.Modules.Entitlements.Application</PackageId>
    <Description>Application layer for the Entitlements module. IEntitlementService, authorization handlers.</Description>
    <Title>SaasBuilder Entitlements Application</Title>
    <Authors>SaasBuilder</Authors>
    <Company>SaasBuilder</Company>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/saasbuilder/modular-sdk-dotnet</RepositoryUrl>
    <PackageTags>saasbuilder;entitlements;application</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Entitlements.Domain\Entitlements.Domain.csproj" />
    <ProjectReference Include="..\..\..\SaasBuilder.SharedKernel\SaasBuilder.SharedKernel.csproj" />
  </ItemGroup>

  <ItemGroup Label="ASP.NET Core Authorization">
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup Label="Versioning">
    <PackageReference Include="MinVer" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="Analyzers — build-time only">
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="StyleCop configuration">
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)..\..\..\..\stylecop.json" />
  </ItemGroup>

  <PropertyGroup>
    <!-- SA1202: public/private member ordering — relaxed for static helper methods in primary constructor classes. -->
    <NoWarn>$(NoWarn);SA1101;SA1309;SA0001;SA1600;SA1200;SA1009;SA1202</NoWarn>
  </PropertyGroup>

</Project>
