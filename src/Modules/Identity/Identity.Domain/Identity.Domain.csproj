<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <Description>Domain model for the Identity module. Zero infrastructure dependencies.</Description>
  </PropertyGroup>

  <!--
    Domain layer must have ZERO dependencies on EF Core / ASP.NET Core / MassTransit /
    OpenIddict / FluentValidation. NetArchTest enforces this in Phase 9.
    Only Microsoft.Extensions.* abstractions are permitted via transitive SharedKernel reference.
  -->

  <ItemGroup>
    <ProjectReference Include="..\..\..\Chassis.SharedKernel\Chassis.SharedKernel.csproj" />
  </ItemGroup>

  <ItemGroup Label="Analyzers — build-time only">
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="StyleCop configuration">
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)..\..\..\..\stylecop.json" />
  </ItemGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);SA1101;SA1309;SA0001;SA1600;SA1200</NoWarn>
  </PropertyGroup>

</Project>
