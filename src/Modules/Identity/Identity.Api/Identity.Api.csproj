<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId>SaasBuilder.Modules.Identity.Api</PackageId>
    <Title>SaasBuilder Identity API</Title>
    <Description>API layer for the Identity module. IModuleStartup implementation and endpoint mapping.</Description>
    <Authors>SaasBuilder Contributors</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/placeholder/modular-sdk-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>saasbuilder;identity;api;endpoints;authorization</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Identity.Infrastructure\Identity.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup Label="Analyzers — build-time only">
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="StyleCop configuration">
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)..\..\..\..\stylecop.json" />
  </ItemGroup>

  <PropertyGroup>
    <!--
      SA1009: StyleCop 1.1.x incorrectly flags C# 12 primary constructor spacing.
      SA1313: StyleCop 1.1.x incorrectly flags PascalCase record positional parameters (idiomatic C# 9+).
      SA1512: single-line comment followed by blank line — false positive in method bodies.
    -->
    <!-- SA1201: StyleCop 1.1.x crashes on RecordDeclaration (KeyNotFoundException bug). -->
    <NoWarn>$(NoWarn);SA1101;SA1309;SA0001;SA1600;SA1200;SA1009;SA1313;SA1512;SA1201</NoWarn>
  </PropertyGroup>

</Project>
