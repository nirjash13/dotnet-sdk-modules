<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId>SaasBuilder.Modules.Admin.Application</PackageId>
    <Title>SaasBuilder Admin Application</Title>
    <Description>Application layer for the Admin/Control-Plane module — handlers, abstractions, validators.</Description>
    <Authors>SaasBuilder Contributors</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/placeholder/modular-sdk-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>saasbuilder;admin;application</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Admin.Contracts\Admin.Contracts.csproj" />
    <ProjectReference Include="..\..\..\SaasBuilder.SharedKernel\SaasBuilder.SharedKernel.csproj" />
    <!-- Identity application abstractions (IInvitationRepository, IPasswordResetService, IImpersonationService) -->
    <ProjectReference Include="..\..\Identity\Identity.Application\Identity.Application.csproj" />
    <!-- Billing application abstractions (ISubscriptionRepository, IBillingProvider) -->
    <ProjectReference Include="..\..\Billing\Billing.Application\Billing.Application.csproj" />
    <!-- Entitlements application abstractions (IEntitlementRepository) -->
    <ProjectReference Include="..\..\Entitlements\Entitlements.Application\Entitlements.Application.csproj" />
    <!-- FeatureFlags application abstractions (IFeatureProvider) -->
    <ProjectReference Include="..\..\FeatureFlags\FeatureFlags.Application\FeatureFlags.Application.csproj" />
    <!-- Jobs application abstractions (IDeadLetterQueueStore) -->
    <ProjectReference Include="..\..\Jobs\Jobs.Application\Jobs.Application.csproj" />
    <!-- Webhooks application abstractions (IWebhookDeliveryQuery, IWebhookSender) -->
    <ProjectReference Include="..\..\Webhooks\Webhooks.Application\Webhooks.Application.csproj" />
    <!-- Notifications application abstractions (INotificationDispatcher) -->
    <ProjectReference Include="..\..\Notifications\Notifications.Application\Notifications.Application.csproj" />
    <!-- Audit application abstractions (IAuditLogger) -->
    <ProjectReference Include="..\..\Audit\Audit.Application\Audit.Application.csproj" />
  </ItemGroup>

  <ItemGroup Label="Validation">
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
  </ItemGroup>

  <ItemGroup Label="Versioning">
    <PackageReference Include="MinVer" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="Analyzers — build-time only">
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="StyleCop configuration">
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)..\..\..\..\stylecop.json" />
  </ItemGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);SA1101;SA1309;SA0001;SA1600;SA1200;SA1009;SA1313;SA1512</NoWarn>
  </PropertyGroup>

</Project>
