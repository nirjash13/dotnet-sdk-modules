<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId>SaasBuilder.Modules.Admin.Infrastructure</PackageId>
    <Title>SaasBuilder Admin Infrastructure</Title>
    <Description>Infrastructure layer for the Admin module — DbContext, service implementations, EF migrations.</Description>
    <Authors>SaasBuilder Contributors</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/placeholder/modular-sdk-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>saasbuilder;admin;infrastructure</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Admin.Application\Admin.Application.csproj" />
    <ProjectReference Include="..\..\..\SaasBuilder.Persistence\SaasBuilder.Persistence.csproj" />
    <!-- Identity infrastructure for Organization/Member queries -->
    <ProjectReference Include="..\..\Identity\Identity.Infrastructure\Identity.Infrastructure.csproj" />
    <!-- Billing infrastructure for subscription queries -->
    <ProjectReference Include="..\..\Billing\Billing.Infrastructure\Billing.Infrastructure.csproj" />
    <!-- Audit infrastructure for audit log queries -->
    <ProjectReference Include="..\..\Audit\Audit.Infrastructure\Audit.Infrastructure.csproj" />
    <!-- FeatureFlags infrastructure for override persistence -->
    <ProjectReference Include="..\..\FeatureFlags\FeatureFlags.Infrastructure\FeatureFlags.Infrastructure.csproj" />
    <!-- Entitlements infrastructure for IEntitlementRepository -->
    <ProjectReference Include="..\..\Entitlements\Entitlements.Infrastructure\Entitlements.Infrastructure.csproj" />
    <!-- Webhooks infrastructure for IWebhookDeliveryQuery, IWebhookSender -->
    <ProjectReference Include="..\..\Webhooks\Webhooks.Infrastructure\Webhooks.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup Label="EF Core + Npgsql">
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="ASP.NET Core — for IHealthCheckService, IHttpContextAccessor">
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup Label="Versioning">
    <PackageReference Include="MinVer" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="Analyzers — build-time only">
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Label="StyleCop configuration">
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)..\..\..\..\stylecop.json" />
  </ItemGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);SA1101;SA1309;SA0001;SA1600;SA1200;SA1009;SA1313;SA1512</NoWarn>
  </PropertyGroup>

</Project>
