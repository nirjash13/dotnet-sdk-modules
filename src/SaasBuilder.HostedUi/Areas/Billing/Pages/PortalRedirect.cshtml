@page
@model SaasBuilder.HostedUi.Areas.Billing.Pages.PortalRedirectModel
@{
    Layout = null;
    ViewData["Title"] = "Opening Billing Portal...";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gray-50 flex items-center justify-center">
    <div class="text-center">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="max-w-sm bg-white rounded-2xl shadow-md p-8">
                <p class="text-red-600 font-medium">@Model.ErrorMessage</p>
                <a href="/" class="mt-4 inline-block text-indigo-600 hover:underline text-sm">Return home</a>
            </div>
        }
        else
        {
            <div class="max-w-sm bg-white rounded-2xl shadow-md p-8">
                <div class="animate-spin inline-block w-8 h-8 border-4 border-indigo-500 border-t-transparent rounded-full mb-4"></div>
                <p class="text-gray-600">Redirecting to billing portal...</p>
            </div>
        }
    </div>
</body>
</html>
