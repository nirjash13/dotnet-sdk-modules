{
  "ReverseProxy": {
    "Routes": {
      "ledger-primary": {
        "ClusterId": "chassis-host-primary",
        "Match": {
          "Path": "/api/ledger/{**catch-all}"
        },
        "Metadata": {
          "canary": "0.05"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Forwarded-Host",
            "Append": "{Host}"
          },
          {
            "RequestHeaderOriginalHost": "true"
          },
          {
            "RequestHeader": "X-Correlation-Id",
            "Append": "{RequestHeader:X-Correlation-Id}"
          }
        ]
      },
      "ledger-canary": {
        "ClusterId": "chassis-host-canary",
        "Match": {
          "Path": "/api/ledger/canary/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Forwarded-Host",
            "Append": "{Host}"
          },
          {
            "RequestHeaderOriginalHost": "true"
          }
        ]
      }
    },
    "Clusters": {
      "chassis-host-primary": {
        "Destinations": {
          "primary": {
            "Address": "https://localhost:5001"
          }
        }
      },
      "chassis-host-canary": {
        "Destinations": {
          "canary": {
            "Address": "https://localhost:5001"
          }
        },
        "Metadata": {
          "canary-weight": "0.05"
        }
      }
    }
  }
}
