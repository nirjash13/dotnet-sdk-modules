## .NET gitignore (dotnet new gitignore baseline)

# Build output
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/

# Visual Studio files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# VS Code
.vscode/

# Rider / JetBrains
.idea/
*.DotSettings.user

# NuGet
*.nupkg
*.snupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# .NET CLI
.dotnet/

# ASP.NET Core Data Protection
keys/

# Environment / secrets — never commit these
.env
.env.*
appsettings.Local.json
appsettings.*.Local.json
secrets.json

# OS
.DS_Store
Thumbs.db
desktop.ini
