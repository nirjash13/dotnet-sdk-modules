@page "/members"
@using MudBlazor
@using SaasBuilder.Starter.Blazor.Services
@inject ApiClient Client
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Team Members — SaasBuilder</PageTitle>

<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4">Team Members</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="OpenInviteDialog">
        Invite Member
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudTable Items="_members" Hover="true" Striped="true" Dense="false"
              Loading="_loading" LoadingProgressColor="Color.Primary"
              Filter="FilterMember" @bind-SelectedItem="_selected">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchTerm" Placeholder="Search members"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" Immediate="true" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Status</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <div class="d-flex align-center">
                    <MudAvatar Size="Size.Small" Color="Color.Primary" Class="mr-2">
                        @context.Name[0]
                    </MudAvatar>
                    @context.Name
                </div>
            </MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Role">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Role == "Owner" ? Color.Primary : Color.Default)">
                    @context.Role
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Status == "Active" ? Color.Success : Color.Warning)">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                    <MudMenuItem OnClick="() => OpenRoleDialog(context)">Change Role</MudMenuItem>
                    <MudMenuItem OnClick="() => RemoveMember(context)"
                                 Disabled="@(context.Role == "Owner")">
                        Remove
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No members found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<MemberDto> _members = new();
    private MemberDto? _selected;
    private string _searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Client.AccessToken is null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadMembersAsync();
    }

    private async Task LoadMembersAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var result = await Client.GetAsync<MembersResponse>("/api/v1/identity/members");
            _members = result?.Items ?? new();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterMember(MemberDto member)
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            return true;
        }

        return member.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
            || member.Email.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OpenInviteDialog()
    {
        var parameters = new DialogParameters<InviteDialog>();
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<InviteDialog>("Invite Member", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var email = (string)result.Data!;
            await SendInviteAsync(email);
        }
    }

    private async Task SendInviteAsync(string email)
    {
        try
        {
            await Client.PostAsync("/api/v1/identity/invitations", new { Email = email, Role = "Member" });
            Snackbar.Add($"Invitation sent to {email}", Severity.Success);
            await LoadMembersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenRoleDialog(MemberDto member)
    {
        var parameters = new DialogParameters<RoleChangeDialog>
        {
            { d => d.MemberName, member.Name },
            { d => d.CurrentRole, member.Role },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RoleChangeDialog>("Change Role", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var newRole = (string)result.Data!;
            try
            {
                await Client.PostAsync($"/api/v1/identity/members/{member.Email}/role",
                    new { Role = newRole });
                Snackbar.Add("Role updated.", Severity.Success);
                await LoadMembersAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async Task RemoveMember(MemberDto member)
    {
        try
        {
            await Client.DeleteAsync($"/api/v1/identity/members/{member.Email}");
            Snackbar.Add($"{member.Name} removed.", Severity.Info);
            await LoadMembersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private sealed record MemberDto(string Name, string Email, string Role, string Status);
    private sealed record MembersResponse(List<MemberDto> Items, int Total);
}
