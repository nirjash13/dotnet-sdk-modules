<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Configured via CI secrets (NUGET_FEED_URL / NUGET_API_KEY) -->
    <!-- <add key="internal" value="$(NUGET_FEED_URL)" /> -->
  </packageSources>
  <packageSourceCredentials>
    <!-- internal credentials are injected at runtime via environment variables, never stored here -->
  </packageSourceCredentials>
</configuration>
